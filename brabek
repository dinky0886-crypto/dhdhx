local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- [ 1. واجهة الشات (فوق يسار) ]
local ScreenGui = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
local ChatBox = Instance.new("TextLabel", ScreenGui)
ChatBox.Size = UDim2.new(0, 250, 0, 50)
ChatBox.Position = UDim2.new(0.01, 0, 0.05, 0)
ChatBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
ChatBox.BackgroundTransparency = 0.5
ChatBox.TextColor3 = Color3.new(1, 1, 1)
ChatBox.Text = "في انتظار رسائل..."

-- [ 2. دالة الإرسال (تغيير اسم ObjectValue في الشخصية) ]
local function setupRadioForMe()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local RadioTag = Instance.new("StringValue", char)
    RadioTag.Name = "RADIO_TAG"
    RadioTag.Value = ""
    return RadioTag
end

local myRadio = setupRadioForMe()

local function sendMessage(msg)
    myRadio.Value = msg
    task.delay(4, function() myRadio.Value = "" end)
end

-- [ 3. الاستقبال (مراقبة جميع اللاعبين - حتى الجدد) ]
local function monitorPlayer(player)
    player.CharacterAdded:Connect(function(char)
        -- ننتظر ظهور الـ RadioTag الخاص باللاعب
        local tag = char:WaitForChild("RADIO_TAG", 10) 
        if tag then
            tag.Changed:Connect(function()
                if tag.Value ~= "" then
                    ChatBox.Text = player.Name .. ": " .. tag.Value
                end
            end)
        end
    end)
end

-- مراقبة الموجودين حالياً
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then monitorPlayer(p) end
end

-- مراقبة اللاعبين الذين سيدخلون لاحقاً
Players.PlayerAdded:Connect(function(p)
    monitorPlayer(p)
end)
